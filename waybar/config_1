{
    "output": ["eDP-1", "HDMI-A-1"],
    "position": "top",
        "layer": "bottom",

        "modules-left":
        [
            "hyprland/workspaces",
            "custom/dot",
            "custom/basilk",
            "custom/dot",
            "custom/basilk_pe",
            "custom/dot",
            "battery"
        ],

        "modules-right":
        [
            "tray",
            "custom/dot",
            "network",
            "custom/dot",
            "cpu",
            "custom/dot",
            "temperature",
            "custom/dot",
            "memory",
            "custom/dot",
            "pulseaudio",
            "custom/dot",
            "clock#date",
            "custom/dot",
            "clock"
        ],

        "modules-center":
        [
            "custom/spotify",
            "custom/cava"
        ],

        "hyprland/workspaces": {
            "disable-scroll": true,
            "all-outputs": false,
            "format": "{name}"
        },
        "hyprland/window": {
            "max-length": 60,
            "format": "Ôčź  {}",
            "rewrite": {
                "Ôčź ":"Ôčź empty"
            },
            "separate-outputs": true
        },
        "custom/dot":{
            "format": "::",
            "interval": 100
        },
        "custom/spotify": {
            "exec": "/home/stanik/scripts/waybar/music_panel.sh",
            "exec-if": "pgrep mpv || pgrep spotify",
            "format": "‚ô™ {text}",
            "states": {
                "playing": "Playing",
                "paused": "Paused",
                "stopped": "Stopped"
            },
            "on-click": "playerctl -p mpv play-pause || playerctl -p spotify play-pause",
            "on-scroll-up": "playerctl next",
            "on-scroll-down": "playerctl previous",
            "return-type": "json",
            "interval": 1
        },
        "custom/vis": {
            "exec": "/home/stanik/scripts/someRandomThing/loadingBar/v2/a.out",
            "format": "{}",
            "interval": 1
        },
        "custom/basilk": {
            "exec": "/home/stanik/scripts/waybar/basilk_panel.sh",
            "format": "ÓąĮ  {}",
            "on-click": "kitty -e basilk"
        },
        "custom/basilk_pe": {
            "exec": "/home/stanik/scripts/waybar/basilk_pe_panel.sh",
            "format": "‚Ě§  {}",
            "on-click": "kitty -e basilk_pe"
        },
        "custom/cava": {
            "format": "{}",
            "exec": "~/.config/waybar/bin/waybarcava.py braille",
            "return-type": "json",
            "restart-interval": 0,
            "max-length": 30,
            "tooltip": false,
            "signal": 1,
            "on-click": "playerctl play-pause",
            "on-click-right": "playerctl next",
            "on-scroll-up": "playerctl position 5+",
            "on-scroll-down": "playerctl position 5-"
        },
        "disk": {
            "interval": 30,
            "format": "Ôā† {percentage_used}%",
            "path": "/"
        },
        "sway/mode": {
            "format": "<span style=\"italic\">{}</span>"
        },
        "tray": {
            "spacing": 10,
            "format": "::"
        },
        "clock#date": {
            "timezone": "Europe/Moscow",
            "format":"ÔĄ≥  {:%d %b}",
            "interval": 1,
            "on-click": "zenity --calendar"
        },
        "clock": {
            "timezone": "Europe/Moscow",
            "format":"{:%H:%M:%S}",
            "interval": 1,
            "on-click": "zenity --calendar"
        },
        "cpu": {
            "interval": 1,
            "format": "Ôíľ  {usage}%",
            "states": {
                "warning": 50,
                "critical": 80
            }
        },
        "temperature": {
            "critical-threshold": 80,
            "format-critical": "Ôčá {temperatureC}¬įC",
            "format": "Ôčá {temperatureC}¬įC"
        },
        "battery": {
            "format": "{icon} {capacity}% - {time}",
            "format-icons": ["ÔČĄ ", "ÔČÉ ", "ÔČā ", "ÔČĀ ", "ÔČÄ "],
            "format-time": "{H}h{M}m",
            "format-charging": "ÔÉß {icon} {capacity}% - {time}",
            "format-full": "",
            "interval": 10,
            "states": {
                "warning": 25,
                "critical": 10
            },
            "tooltip": false,
            "on-click": "2"
        },
        "memory": {
            "interval": 1,
            "format": "RAM {used:}MiB",
            "states": {
                "warning": 75,
                "critical": 90
            }
        },
        "network": {
            "format-wifi": "Ôáę  ({signalStrength}%)",
            "format-ethernet": "ůįąĀ",
            "format-linked": "{ůįĄ° {ifname} (No IP)",
            "format-disconnected": "Óęź ",
            "format-alt": "{ifname}: {ipaddr}/{cidr}"
        },
        "pulseaudio/slider": {
            "min": 0,
            "max": 100,
            "orientation": "horizontal"
        },
        "pulseaudio": {
            "scroll-step": 5,
            "format": "{icon} {volume}%",
            "format-muted": "ÔĎ¶ ",
            "format-icons": {
                "default": ["ÔÄ¶", "ÔÄß ", "ÔÄ® "]
            },
            "on-click": "pavucontrol",
            "on-click-middle": "pamixer -t",
            "states": {
                "normal": 80,
                "warning": 99,
                "critical": 999
            }
        },
}
